# NavPro API (TruckerPath Dispatcher OS)
NAVPRO_API_BASE_URL=https://api.truckerpath.com/navpro
NAVPRO_API_BEARER_TOKEN=

# InsForge
# When these are unset, the app falls back to high-quality demo mode for the dispatcher dashboard.
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Map tile provider: "osm" (default) or "here"
NEXT_PUBLIC_MAP_PROVIDER=osm

# HERE Maps tile API key (only used when NEXT_PUBLIC_MAP_PROVIDER=here)
NEXT_PUBLIC_HERE_API_KEY=
