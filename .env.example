# NavPro API (Trucker Path Fleets)
NAVPRO_API_BASE_URL=https://api.truckerpath.com/navpro
NAVPRO_API_BEARER_TOKEN=

# Force mock data even if a token is set (useful for demos)
NAVPRO_FORCE_MOCK=false

# Map tile provider: "osm" (default) or "here"
NEXT_PUBLIC_MAP_PROVIDER=osm

# HERE Maps tile API key (only used when NEXT_PUBLIC_MAP_PROVIDER=here)
NEXT_PUBLIC_HERE_API_KEY=
